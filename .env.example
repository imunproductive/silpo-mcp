# Remote (HTTP) mode configuration — used by `npm run start:http` (dist/http.js).
# The stdio mode (dist/index.js) needs none of these.

# Public HTTPS URL of this server (OAuth issuer). Required.
SILPO_MCP_BASE_URL=https://silpo.example.com

# Login password that gates access on the authorization page. Required.
SILPO_MCP_PASSWORD=change-me-to-a-strong-password

# Port to listen on (behind your HTTPS reverse proxy). Optional, default 3000.
SILPO_MCP_PORT=3000

# Access-token lifetime in seconds. Optional, default 2592000 (30 days).
SILPO_MCP_TOKEN_TTL=2592000

# Where OAuth state (clients + tokens) and Silpo session (address, basketId,
# cabinet token, cart) are persisted so restarts don't force re-auth. Both are
# written 0600. Optional — defaults are relative to the working directory.
# SILPO_MCP_STATE_FILE=/var/lib/silpo-mcp/state.json
# SILPO_MCP_SESSION_FILE=/var/lib/silpo-mcp/session.json

# Optional: pre-registered static OAuth client, for Claude's "Client ID / Secret"
# fields. Leave unset to rely on Dynamic Client Registration (recommended).
# SILPO_OAUTH_CLIENT_ID=my-claude-client
# SILPO_OAUTH_CLIENT_SECRET=some-long-random-secret
# SILPO_OAUTH_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback
